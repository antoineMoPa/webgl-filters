{
  "name": "webgl-filters",
  "version": "0.8.1",
  "description": "GPU-accelerated image filters using WebGL shaders",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:demo": "tsup --config tsup.demo.config.ts",
    "build:docs": "typedoc",
    "build:video-demo": "tsup --config tsup.video-demo.config.ts",
    "build:site": "mkdir -p docs/demo docs/video-demo && cp site/.nojekyll site/index.html docs/ && cp site/demo/index.html docs/demo/ && cp site/video-demo/index.html docs/video-demo/ && npm run build:demo && npm run build:video-demo && npm run build:docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "webgl",
    "image",
    "filter",
    "shader",
    "gpu",
    "contrast",
    "brightness",
    "blur",
    "sharpen",
    "convolution"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/antoineMoPa/webgl-filters.git"
  },
  "homepage": "https://antoinemopa.github.io/webgl-filters/api/",
  "devDependencies": {
    "@types/gl": "^6.0.5",
    "gl": "^8.1.6",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "gl": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "gl": {
      "optional": true
    }
  }
}
